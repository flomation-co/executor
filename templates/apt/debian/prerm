#!/bin/sh
# prerm script for {{PACKAGE_NAME}}
# Equivalent to RPM %preun section
# shellcheck disable=SC1083,SC2154
# Note: This is a template file with {{PLACEHOLDERS}} that will be replaced during build

set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop and disable the service before removal/upgrade
        if command -v systemctl >/dev/null 2>&1; then
            systemctl --no-reload disable {{PACKAGE_NAME}}.service >/dev/null 2>&1 || true
            systemctl stop {{PACKAGE_NAME}}.service >/dev/null 2>&1 || true
        fi
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
